<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/Kuestenlogik/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <!-- Surgewave-Client + Schema-Registry-Pakete kommen von
           GitHub Packages (bzw. fuer stable Tags zusaetzlich von
           nuget.org). Pattern faengt alle Library-Packages von
           Kuestenlogik.Surgewave.* ab. -->
      <package pattern="Kuestenlogik.Surgewave.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
